# ============================================================
# INDIA HEALTH INSURANCE PLATFORM — ENVIRONMENT VARIABLES
# ============================================================
# Copy this file to .env.local for local development.
# NEVER commit .env.local to git.
# For production: set all variables in Vercel Dashboard.
# ============================================================

# ── APP ──────────────────────────────────────────────────────
# Next.js + NextAuth
NEXTAUTH_SECRET=change_me_to_32_plus_random_chars_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXTAUTH_URL=http://localhost:3000
# Prod: NEXTAUTH_URL=https://your-app.vercel.app

# Separate JWT secret for customer OTP sessions
JWT_SECRET=change_me_to_32_plus_random_chars_yyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy

# Default mode for newly created insurers: 'test' or 'live'
APP_DEFAULT_MODE=test
APP_ALLOW_INSECURE_TLS=false
APP_USE_PGLITE=false
PGLITE_DATA_DIR=./.local-db/pglite
APP_EXPOSE_TEST_OTP=false

# ── DATABASE ─────────────────────────────────────────────────
# Neon PostgreSQL — database: india_health_db
# Get from: console.neon.tech → your project → Connection String
DATABASE_URL=postgres://user:password@ep-xxx-xxx.us-east-2.aws.neon.tech/india_health_db?sslmode=require

# ── PAYMENT (RAZORPAY) ───────────────────────────────────────
# Controls which keys are used (test or live) — GLOBAL, NOT per-insurer
RAZORPAY_MODE=test

# Test keys (from Razorpay Dashboard → Test Mode)
RAZORPAY_TEST_KEY_ID=rzp_test_xxxxxxxxxxxxxxxxxxxxx
RAZORPAY_TEST_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Live keys (from Razorpay Dashboard → Live Mode) — leave empty until going live
RAZORPAY_LIVE_KEY_ID=
RAZORPAY_LIVE_KEY_SECRET=

# Razorpay webhook secret (from Razorpay Dashboard → Webhooks)
# Set webhook URL to: https://your-app.vercel.app/api/webhooks/razorpay
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# ── STORAGE (CLOUDINARY) ─────────────────────────────────────
# From: console.cloudinary.com → Settings → API Keys
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=xxxxxxxxxxxxxxxxxxxx
CLOUDINARY_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Root folder — all insurer assets stored under this prefix
CLOUDINARY_FOLDER=india-health

# ── EMAIL (BREVO) ────────────────────────────────────────────
# From: app.brevo.com → SMTP & API → API Keys
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-xxxxxxxx
BREVO_SENDER_EMAIL=noreply@yourplatform.com
BREVO_SENDER_NAME=Health Insurance Platform
# Optional: Brevo SMS sender ID (max 11 chars)
BREVO_SMS_SENDER=HLTHINS

# ── EXTERNAL APIs (PLATFORM-LEVEL FALLBACK) ─────────────────
# These are FALLBACK credentials used if an insurer does not have
# their own credentials configured in the insurer_api_credentials table.
# Per-insurer credentials stored in DB take priority over these env vars.
# Leave empty for pure local dev (will auto-mock all external APIs).

# iAdore (Perfios) — Demographic Profiling
IADORE_BASE_URL=
IADORE_ORG_KEY=
IADORE_HMAC_KEY=
IADORE_INCOME_API_URL=

# Karza — TKYC (ID Verification) + OCR Plus (Document Digitization)
KARZA_BASE_URL=
KARZA_API_KEY=

# ProtectMeWell — Needs Analysis
PMW_BASE_URL=
PMW_API_KEY=

# Quote Generation API
QUOTE_API_URL=
QUOTE_API_KEY=

# NuralX (Beaive) — Face Biometric Vitals
NURALX_BASE_URL=
NURALX_EMAIL=
NURALX_PASSWORD=
# Must be a public HTTPS URL — NuralX POSTs vitals here after each scan:
NURALX_CALLBACK_URL=https://your-app.vercel.app/api/webhooks/nuralx

# PIVC — Pre-Issuance Verification Call
PIVC_BASE_URL=
PIVC_API_KEY=

# STP Engine — Underwriting Decision
STP_API_URL=
STP_API_KEY=

# ── INTERNAL ─────────────────────────────────────────────────
# Secret for cron job / scheduled tasks (if any)
CRON_SECRET=change_me_to_random_string

# ── NOTES ────────────────────────────────────────────────────
# 1. All external API env vars above are OPTIONAL for local development.
#    If empty, the api-router will auto-detect missing credentials and
#    use mock responses instead (same as insurer test mode).
#
# 2. For production, add all required values to Vercel Dashboard:
#    Project → Settings → Environment Variables → Production
#
# 3. Per-insurer API credentials are stored in the database (insurer_api_credentials table)
#    and managed via the Admin portal at /admin/insurers/{id}/credentials
#    These take priority over the env vars above.
#
# 4. RAZORPAY_MODE controls test vs live payments globally.
#    To switch to live payments: change RAZORPAY_MODE=live in Vercel and redeploy.
#
# 5. To add a new insurer: use the Admin portal at /admin/insurers/new
